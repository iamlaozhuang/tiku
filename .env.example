# ============================================================
# Tiku 环境变量模板
# 复制为 .env.local 后填入真实值
# ============================================================

# 数据库
DATABASE_URL=postgresql://user:password@localhost:5432/tiku

# 认证 (Better Auth)
BETTER_AUTH_SECRET=your-secret-key-min-32-chars

# AI 模型（按需启用）
ALIBABA_API_KEY=
OPENAI_API_KEY=
