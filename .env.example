# ============================================================
# Tiku 环境变量模板
# 复制为 .env.local 后填入真实值
# ============================================================

# 数据库
DATABASE_URL=postgresql://user:password@localhost:5432/tiku

# 认证 (Better Auth)
BETTER_AUTH_SECRET=your-secret-key-min-32-chars

# AI 模型（按需启用；仅模板占位，真实值不要提交）
AI_PROVIDER_ENABLED=false
ALIBABA_API_KEY=
OPENAI_API_KEY=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
