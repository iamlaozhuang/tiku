  "securityContract": {
    "schema": "Question generation accepts only one versioned canonical JSON question-set schema. Plaintext, aliases outside the allowlist, unknown keys, missing fields, malformed options, and type-incompatible answer structures fail closed.",
    "count": "Every successful consumer receives exactly requestedQuestionCount complete drafts. No find, filter, or partial subset may remain successful.",
    "snapshot": "A successful personal ai_question_generation result atomically stores one immutable server-created snapshot, schema version, and digest derived from the validated drafts and evidence; legacy rows remain explicitly unavailable.",
    "learning": "Learning-session creation accepts only sourceResultPublicId and explicit non-content confirmation parameters, rechecks current authorization and owner scope, and builds from the persisted snapshot. Client question, answer, analysis, evidence, or digest input is ignored or rejected.",
    "privacy": "History and detail DTOs remain redacted and never expose the private question snapshot, answers, analysis, raw Provider output, prompt, RAG text, credentials, or internal ids.",
    "scope": "Migration source is additive and nullable for legacy compatibility; no migration apply, real database, real Provider call, permission, dependency, mechanism, F-0154, or formal-domain expansion."
  },
  "acceptance": [
    "plain text and incomplete, malformed, extra-field, mixed-validity, or wrong-count JSON produce no successful result",
    "single_choice, multi_choice, true_false, fill_blank, short_answer, case_analysis, and calculation use explicit type-aware completeness rules",
    "content, organization, personal, and employee consumers preserve exact requested question count and cannot silently shrink",
    "personal result persistence atomically stores canonical snapshot version and digest only for successful complete question sets",
    "same result replay reuses one immutable snapshot; conflicting snapshot or digest fails closed",
    "learning session request uses only sourceResultPublicId and current authorization; client-forged content and evidence cannot affect stored questions",
    "refresh and cross-device resume reconstruct the same private questions from the server snapshot",
    "legacy result without snapshot returns a stable unavailable state and never fabricates questions",
    "history and detail remain redacted and no private snapshot fields cross the API boundary"
  ],
