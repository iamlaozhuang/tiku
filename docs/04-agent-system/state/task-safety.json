    "validationReferencedTestsPreallowed": true,
    "confirmedRootCause": "F-0025 moved idempotent claim before Provider but production routes still do not persist running or failure transitions, admin success remains a result/task double write, and no owner-authorized cancellation or bounded stale-running retry command consumes the existing lifecycle fields",
    "residualDisposition": {
      "F-0148": "separate_blocked_product_decision_cost_calibration_and_quota_SSOT",
      "F-0149": "current_confirmed_root_cause_task"
    }
  },
  "lifecycleContract": {
    "attemptIdentity": "The authoritative execution attempt is the tuple taskPublicId plus retryCount plus startedAt; every fail or success update CAS-matches the running attempt so late completion cannot overwrite cancellation or a newer retry.",
    "claim": "A created pending task must become running before Provider or paper assembly. A retryable failed task or running task stale for at least five minutes may be claimed by the same canonical intent; active running work cannot be duplicated.",
    "retryLimit": "At most two retry claims after the initial attempt are allowed. Non-retryable failure, succeeded, cancelled, or exhausted work is never re-executed.",
    "failure": "Provider, structure, paper assembly, or result persistence failure writes only a stable redacted failure category, finishedAt, and current retry state; no raw Provider error, prompt, generated content, credential, or internal exception is persisted or returned.",
    "success": "Admin and personal result insertion and task succeeded transition occur in one transaction and only for the current running attempt; task update failure rolls back the result.",
    "cancel": "Only the already-authorized task owner surface may cancel its own pending or running task by publicId. Authorization precedes task lookup, cancellation is terminal, and any later Provider completion is rejected.",
    "replay": "The unchanged stable idempotency intent may claim only an eligible failed or stale attempt. Concurrent replay has one winner; all other callers observe current state without Provider execution.",
    "compatibility": "Existing succeeded results, redacted history, formal-adoption blocks, authorization scope, quota placeholders, Provider configuration, and API envelopes remain unchanged."
  },
  "acceptance": [
    "admin and personal created tasks persist running before any Provider or paper assembly work",
    "Provider validation assembly and persistence failures persist a stable redacted failure category retry count and terminal time",
    "admin and personal result plus succeeded task state are one transaction and late attempts cannot win",
    "same canonical intent may retry retryable failed or five-minute stale running work at most twice while active running and terminal tasks never duplicate Provider execution",
    "only the current authorized owner surface can cancel by task publicId and cancelled work rejects late success",
    "history and UI expose status safe failure retry count and whether retry or cancellation is available without sensitive input output or internal identity",
    "no schema migration real database execution quota entitlement Provider configuration dependency or mechanism change"
  ],
