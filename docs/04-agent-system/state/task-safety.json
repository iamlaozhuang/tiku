  "authoritativeChainEvidence": {
    "uiApi": "AdminOrgAuthRedeemPage currently loads organizations, org_auths and employees with one fixed page=1&pageSize=20 snapshot, then reuses those arrays for org-auth creation, employee create/import and transfer review. AdminOpsManagement already contains a tested searchable organization picker suitable for extraction and reuse.",
    "routeService": "The organization list API already supports keyword/status/page/pageSize. The employee transfer route currently exposes only POST; adding a read-only GET preflight on the same public-id route can share the existing employee-manager authorization boundary.",
    "repository": "The existing transfer command atomically locks and revalidates target organization and quota reservation. A read-only preflight must query the same current organization-coverage and quota facts without reserving quota, while POST remains the final fail-closed authority.",
    "schema": "Existing organization revision, org_auth coverage, account_quota and employee_org_auth reservation facts are sufficient. No schema/migration source or persistent database execution is required.",
    "tests": "Focused RED will cover the 21st/101st active organization, picker search/pagination/race recovery, repository-authoritative transfer preview, stale preview followed by POST rejection, and no first-page org_auth inference; direct mocks and regressions are pre-allowlisted.",
    "requirements": "docs/01-requirements/modules/06-admin-ops.md and the 2026-07-02 operations authorization UI/UX contract require explicit target selection plus inherited authorization/quota preflight; cross-cutting list rules prohibit treating a fixed first page as a complete reference directory.",
    "nonClaims": "No new role, entitlement, authorization source, quota rule, schema/migration, real database access, dependency, Provider, external service, secret/env, deployment, PR, force-push or mechanism change."
  },
