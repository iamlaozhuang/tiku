  "lifecycleContract": {
    "receipt": "After the private file is durably stored, create exactly one resource row in uploaded state and complete the upload operation with its existing idempotency binding and redacted audit in one transaction.",
    "claim": "Atomically claim uploaded or conversion_failed and only an explicitly stale converting row; return a claim version derived from authoritative updated_at so concurrent workers and replays cannot share ownership.",
    "finalize": "Finalize draft or conversion_failed only when public identity, converting state, source identity, and claim version all still match; a superseded worker cannot overwrite a newer attempt.",
    "retry": "Only existing super_admin or content_admin may POST the public-id retry command; invalid state, active claim, unknown resource, and identity drift fail closed with no parser or file access before authorization.",
    "failure": "Conversion errors persist only a stable redacted reason, return a non-success response for the command, stay nonpublishable and outside RAG, and remain deterministically retryable.",
    "preservation": "Do not change schema, upload byte storage, the office converter, resource authorization, publish or RAG semantics, or claim durable background queue, delete recovery, deployment-wide concurrency, or OS-level containment."
  },
