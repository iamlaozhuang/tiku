  "authorizationLineageContract": {
    "newSession": "server persists exact authorizationSource, authorizationPublicId, organizationPublicId and quota owner snapshot selected from the current user's effective contexts; dual-context requests cannot rely on an ambiguous union",
    "revalidation": "lineaged sessions require the same exact authorization context to remain effective; another source covering the same profession/level never silently replaces it",
    "orgAuthCancellation": "terminate only active sessions whose source is org_auth and whose exact authorizationPublicId matches the cancelled org_auth",
    "organizationDisable": "terminate only active org_auth sessions whose captured organizationPublicId is in the disabled organization set",
    "employeeDisable": "account disable continues to terminate every active session for that disabled user with account_disabled because no authorization source remains usable",
    "legacyCompatibility": "pre-migration all-null sessions remain legacy union-authorized and are not guessed as org_auth during bulk cancellation; their next access reuses the existing effective-union check and terminates only when no effective covering authorization remains",
    "contextChange": "a lineaged active session cannot be silently resumed under a different requested authorization; mismatch fails closed without rewriting lineage",
    "transactionality": "lineage is inserted atomically with the session and database checks require either all lineage fields null or a coherent complete snapshot"
  },
  "acceptance": [
    "new practice and mock_exam rows persist one coherent server-owned authorization lineage snapshot atomically",
    "personal_auth-backed sessions survive unrelated org_auth cancellation and organization disable",
    "org_auth-backed sessions terminate on exact org_auth cancellation or captured organization disable even when personal_auth also covers the same scope; the user may start a new personal-auth session but the system never switches the active session silently",
    "personal_auth expiry and org_auth expiry/cancel cause exact-lineage revalidation to fail closed without adopting another source",
    "legacy all-null sessions are not guessed or backfilled and retain explicit union-authorization compatibility behavior",
    "cross-subject sessions are governed by source identity rather than coarse profession/level guesses",
    "all termination paths write explicit stable reasons and no unauthorized client-provided lineage is trusted",
    "migration source is additive and nullable with no backfill, UPDATE, DELETE, destructive DDL, apply or real database access",
    "no role, entitlement, quota amount, capability, Provider, dependency, mechanism or external boundary changes"
  ],
