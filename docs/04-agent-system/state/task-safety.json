  "authoritativeChainEvidence": {
    "uiApi": "AdminQuestionMaterialManagementClient currently inserts two nonexistent fixed paper_asset IDs; it must upload a real image first and only then insert an immutable same-origin content_images reference.",
    "handlerService": "A dedicated content-images runtime will keep upload authority limited to existing super_admin/content_admin roles, require any active session for byte reads, and return bytes rather than a JSON metadata envelope.",
    "repositorySchema": "paper_asset is explicitly the original PDF/Word attachment of an existing paper and cannot safely represent pre-paper question/material images. A separate content_image plus durable upload operation is the narrowest complete persistent boundary.",
    "contentMutation": "Question and material validators must reject every external, malformed or legacy paper_asset image even when text is present; services must verify all parsed content_image public IDs exist before repository writes.",
    "studentRendering": "StudentRichText must render only canonical same-origin content_images byte URLs and drop external http(s), legacy paper_asset metadata URLs and malformed sources.",
    "tests": "Focused tests cover MIME/size/path validation, idempotent upload operation and audit, active-session byte delivery, bad/missing/external references, legitimate text/table behavior, UI upload-before-insert and student rendering.",
    "nonClaims": "No migration execution, real database write, external object storage, Provider, dependency, secret/env, deployment, PR, force-push, role creation or entitlement expansion."
  },
