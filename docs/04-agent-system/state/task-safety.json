  "requiredSemantics": {
    "schema": "Add only the eight approved legacy-nullable lifecycle fields, the minimum strict legacy/current coherence checks and one actor-lineage-createdAt-id history index; no defaults, backfill, data SQL or destructive DDL.",
    "lineage": "New sessions bind the server-resolved exact authorization source and public id after the repository transaction revalidates source result/task actor, owner, task type and owner-type mapping; no client lineage is trusted.",
    "serialization": "Answer and complete commands lock the authoritative session row before the exact answer set, use the same order, reject writes after completion and keep persisted updatedAt monotonic.",
    "completion": "One canonical projector creates a detached bounded summary and digest bound to schema, session, revision, actor, owner, authorization lineage, source result/task and immutable question snapshot digest; completion is one exact revision CAS transaction.",
    "replay": "Only exact persisted full-fact completion replay is read-only; stale, different, legacy, partial or corrupt state is a stable masked conflict with zero mutation.",
    "history": "History count, stable order and page are database operations scoped to exact actor and authorization lineage; internal ids remain private.",
    "statistics": "Statistics are database-scoped to exact actor and authorization lineage and completed metrics consume only validated immutable completion summaries; personal and organization contexts never mix.",
    "authorization": "Session, capability and organization authorization precede all session or answer fact reads and mutations; invalid scope stays masked.",
    "legacy": "All-null legacy lifecycle rows remain read-only compatible only through immutable source lineage validation; no completion or statistics is guessed, and partial/corrupt rows fail closed.",
    "publicBoundary": "API and UI expose only allowlisted lifecycle, progress and aggregate facts; authorization ids, answers, question snapshots, standard answers, analysis, citations and internal ids remain private.",
    "unchanged": "F-0162 immutable source, F-0163 answer CAS, F-0157 seven types, subjective review-required, F-0150 redaction, Provider, Prompt and quota semantics remain unchanged; F-0013 stays runtime_hold."
  },
