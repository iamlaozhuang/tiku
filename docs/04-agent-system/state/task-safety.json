  "preRedImpactScan": {
    "authoritativeChain": "Provider attempt boundary -> strict AI call observation v1 -> ai_call_log persisted facts -> provenance-aware operations list and disjoint database summary",
    "currentVulnerableSink": "scoring and explanation use partial character heuristics, the local learning-suggestion mock emits fixed latency, terminal generation usage accepts partial aliases, and operations sums every token/cost value without provenance",
    "securityInvariant": "only a complete validated provider-reported tuple is actual; a complete successful request/response may be explicitly estimated; all other usage is unavailable; latency is measured around the actual attempt and every aggregate keeps sources disjoint",
    "legitimateBehavior": "provider-reported usage remains visible as actual, no-usage successful calls may show labeled estimates, failures or corrupt usage remain unavailable, and legacy rows never become trusted facts",
    "coreFileCount": 34,
    "contingencyFileCount": 38,
    "directCallersMocksFixturesReviewed": true,
    "schemaMigrationRequired": true,
    "migrationApplyOrRealDatabaseRequired": false,
    "realProviderRequired": false,
    "authorizationSemanticsChanged": false,
    "bundleDisposition": "F-0177 is the only independent static RC-08 product residual; F-0013 remains runtime_hold"
  },
  "requiredSemantics": {
    "schema": "additive legacy-nullable observation schema version, token source, token estimation method and latency source with one strict coherence CHECK; no enum expansion, default, backfill, data SQL or apply",
    "tokenTuple": "provider-reported usage requires exact nonnegative safe integer input/output/total with total equal to input plus output; no partial aliases, truthy coercion, clamp, fake zero or inconsistent totals",
    "estimation": "only a successful complete invocation with the full canonical request and normalized response may use the single named deterministic estimator; estimated source and method are mandatory and never presented as actual",
    "unavailable": "failed calls without complete provider usage, malformed usage, blocked calls and legacy rows expose unavailable rather than fabricated counts or zero",
    "latency": "client-observed latency starts immediately before each runner/provider attempt and ends only after output validation; a strict provider-reported duration may be used when available; fixed constants and post-execution adjacent timestamps are forbidden",
    "persistence": "every new running or terminal ai_call_log write carries current observation provenance; repository validates the complete observation before insert/update and preserves current running-log CAS semantics",
    "aggregation": "database list and summary expose token/latency sources; provider-reported token/cost, estimated token/cost, unavailable count and legacy count remain disjoint and no null is coerced into measured zero",
    "privacy": "observation stores only schema version, count source, named estimation method, count tuple, latency source and duration; no prompt, answer, RAG text, provider payload/error, secret, path or internal id",
    "coverage": "scoring, explanation/hint, learning suggestion and route-integrated Provider logs consume the one contract; dormant knowledge recommendation cannot retain a second fake observation algorithm",
    "unchanged": "Provider request count/fallback/lifecycle, Prompt Registry, RAG scope, authorization, quota, Cost Calibration, dependencies, UI capabilities and safety mechanisms remain unchanged"
  },
  "minimumAdversarialTests": [
    "complete provider usage exact positive, missing/extra/duplicate/alias-conflict/non-integer/negative/NaN/Infinity/overflow/total-mismatch rejection",
    "successful no-usage invocation estimates the full canonical request and normalized response with one explicit method; long answer, scoring points, RAG and structured output affect the estimate",
    "failure without usage remains unavailable and does not fabricate completion zero; malformed provider usage cannot silently fall back to actual",
    "each scoring, explanation, hint and learning-suggestion attempt measures the real boundary; fallback attempts have independent clocks and observations; fixed 1000ms and post-execution zero-time patterns disappear",
    "new running and terminal log writes have coherent observation v1; legacy marker all-null remains readable but untrusted; partial markers or tuple/source mismatch fail closed",
    "database summaries keep provider-reported and estimated token/cost totals separate and count unavailable/legacy calls without coalescing them into usage",
    "operations DTO/UI label actual, estimated and unavailable facts and never display legacy/failure null as measured zero",
    "route-integrated provider usage accepts only the canonical exact tuple and carries client-observed latency provenance without weakening redaction",
    "dormant knowledge recommendation service has no fixed/post-execution metrics and can only emit the shared observation contract if wired later",
    "redacted snapshots, pricing version, F-0173 scoring integrity, F-0176 whole-report input, F-0065 lifecycle and generation provenance regressions remain GREEN"
