  "knowledgeSnapshotContract": {
    "container": "knowledgeNodeSnapshot={schemaVersion:1,bindings:[...]} where absence means legacy, present malformed means corrupt and must fail closed",
    "sourceAuthority": "question_knowledge_node joined to the current formal knowledge_node row inside paper composition; unresolved recommendation candidates are excluded until formally confirmed",
    "snapshotFacts": [
      "knowledgeNodePublicId",
      "name",
      "pathName",
      "confirmationStatus=confirmed",
      "bindingSource=formal_question_binding"
    ],
    "determinism": "all direct bindings appear exactly once in ordinal case-sensitive public-id order and remain exactly consistent in count, order and case with existing direct public-id metadata; localeCompare is forbidden",
    "integrity": "unknown fields, missing/duplicate/case-conflicting identities, cross-profession, cross-knowledge-base, cyclic or malformed hierarchy/name/path facts fail closed before paper question persistence",
    "pathProof": "captured pathName must equal the complete root-to-direct node name chain from one transactionally consistent hierarchy read; names and paths are nonempty normalized strings without control characters",
    "transactionConsistency": "binding, question and complete node hierarchy are read as one consistent transaction fact through one recursive statement or explicit locks plus final revalidation",
    "legacy": "existing snapshots without structured knowledge facts remain readable as explicitly legacy/unavailable and are never repaired from the mutable current tree",
    "report": "new report analysis groups by snapshot public id while preserving and displaying the captured name/path; valid empty, legacy unavailable and corrupt present are distinct; mixed legacy/current analytics are unavailable rather than partial",
    "immutability": "knowledge_node rename, move or disable after paper composition cannot alter paper, practice, mock_exam or exam_report history",
    "noSchema": "the change only strengthens existing JSON snapshot application logic; no schema or migration source is modified"
  },
