{
  "$schema": "https://raw.githubusercontent.com/amzn/style-dictionary/main/examples/advanced/design-tokens/tokens.schema.json",
  "name": "Tiku Design System",
  "version": "1.0.0",
  "theme": {
    "light": {
      "color": {
        "brand": {
          "primary": { "value": "#00904A", "type": "color", "description": "中国烟草标准绿，品牌主色" },
          "secondary": { "value": "#F5A623", "type": "color", "description": "中国烟草标准黄，辅助色" }
        },
        "green": {
          "50": { "value": "#ECFDF5", "type": "color" },
          "100": { "value": "#D1FAE5", "type": "color" },
          "200": { "value": "#A7F3D0", "type": "color" },
          "300": { "value": "#6EE7B7", "type": "color" },
          "400": { "value": "#34D399", "type": "color" },
          "500": { "value": "#10B981", "type": "color", "description": "语义成功色" },
          "600": { "value": "#059669", "type": "color" },
          "700": { "value": "#00904A", "type": "color", "description": "同 brand.primary" },
          "800": { "value": "#166534", "type": "color" },
          "900": { "value": "#14532D", "type": "color" }
        },
        "semantic": {
          "success": { "value": "{color.green.500}", "type": "color" },
          "warning": { "value": "{color.brand.secondary}", "type": "color" },
          "error": { "value": "#EF4444", "type": "color" },
          "info": { "value": "#3B82F6", "type": "color" }
        },
        "neutral": {
          "surface": { "value": "#FFFFFF", "type": "color", "description": "卡片、内容区底色" },
          "background": { "value": "#F9FAFB", "type": "color", "description": "页面整体背景" },
          "border": { "value": "#E5E7EB", "type": "color" },
          "border-hover": { "value": "#D1D5DB", "type": "color" }
        },
        "text": {
          "primary": { "value": "#111827", "type": "color" },
          "secondary": { "value": "#6B7280", "type": "color" },
          "muted": { "value": "#9CA3AF", "type": "color" },
          "inverse": { "value": "#FFFFFF", "type": "color", "description": "深色背景上的文字" }
        }
      },
      "shadow": {
        "sm": { "value": "0 1px 2px 0 rgba(0, 0, 0, 0.05)", "type": "shadow" },
        "md": { "value": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)", "type": "shadow" },
        "lg": { "value": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05)", "type": "shadow" }
      }
    },
    "dark": {
      "color": {
        "brand": {
          "primary": { "value": "#4ADE80", "type": "color", "description": "暗黑模式下的品牌绿，提升明度保证对比度" },
          "secondary": { "value": "#FBBF24", "type": "color" }
        },
        "semantic": {
          "success": { "value": "#34D399", "type": "color" },
          "warning": { "value": "{color.brand.secondary}", "type": "color" },
          "error": { "value": "#F87171", "type": "color" },
          "info": { "value": "#60A5FA", "type": "color" }
        },
        "neutral": {
          "surface": { "value": "#1F2937", "type": "color" },
          "background": { "value": "#111827", "type": "color" },
          "border": { "value": "#374151", "type": "color" },
          "border-hover": { "value": "#4B5563", "type": "color" }
        },
        "text": {
          "primary": { "value": "#F9FAFB", "type": "color" },
          "secondary": { "value": "#9CA3AF", "type": "color" },
          "muted": { "value": "#6B7280", "type": "color" },
          "inverse": { "value": "#111827", "type": "color" }
        }
      },
      "shadow": {
        "sm": { "value": "0 1px 2px 0 rgba(0, 0, 0, 0.5)", "type": "shadow" },
        "md": { "value": "0 4px 6px -1px rgba(0, 0, 0, 0.5)", "type": "shadow" },
        "lg": { "value": "0 10px 15px -3px rgba(0, 0, 0, 0.5)", "type": "shadow" }
      }
    }
  },
  "global": {
    "fontFamily": {
      "heading": { "value": "'Noto Sans SC', system-ui, sans-serif", "type": "typography" },
      "body": { "value": "'Noto Sans SC', system-ui, sans-serif", "type": "typography" },
      "mono": { "value": "'JetBrains Mono', monospace", "type": "typography" }
    },
    "fontSize": {
      "xs": { "value": "12px", "type": "typography" },
      "sm": { "value": "14px", "type": "typography" },
      "base": { "value": "16px", "type": "typography" },
      "lg": { "value": "18px", "type": "typography" },
      "xl": { "value": "20px", "type": "typography" },
      "2xl": { "value": "24px", "type": "typography" },
      "3xl": { "value": "30px", "type": "typography" },
      "4xl": { "value": "36px", "type": "typography" }
    },
    "fontWeight": {
      "normal": { "value": "400", "type": "typography" },
      "medium": { "value": "500", "type": "typography" },
      "semibold": { "value": "600", "type": "typography" },
      "bold": { "value": "700", "type": "typography" }
    },
    "spacing": {
      "0": { "value": "0px", "type": "spacing" },
      "1": { "value": "4px", "type": "spacing" },
      "2": { "value": "8px", "type": "spacing" },
      "3": { "value": "12px", "type": "spacing" },
      "4": { "value": "16px", "type": "spacing" },
      "6": { "value": "24px", "type": "spacing" },
      "8": { "value": "32px", "type": "spacing" },
      "12": { "value": "48px", "type": "spacing" },
      "16": { "value": "64px", "type": "spacing" }
    },
    "radius": {
      "none": { "value": "0px", "type": "borderRadius" },
      "sm": { "value": "4px", "type": "borderRadius", "description": "后台端小组件" },
      "md": { "value": "8px", "type": "borderRadius", "description": "后台端卡片 / 学员端小组件" },
      "lg": { "value": "12px", "type": "borderRadius", "description": "学员端卡片" },
      "xl": { "value": "16px", "type": "borderRadius", "description": "学员端大面板" },
      "full": { "value": "9999px", "type": "borderRadius" }
    }
  }
}
