#!/usr/bin/env sh
set -e
push_updates=$(cat)
powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/agent-system/Test-ContentAdminPlatformSerialProgram.ps1 -Phase pre_push
powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/agent-system/Test-ContentAdminPlatformRecoverySurface.ps1
powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/agent-system/Test-P0RemediationSerialProgram.ps1 -Phase pre_push
p1_guard_output=$(printf '%s\n' "$push_updates" | powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/agent-system/Test-P1RemediationSerialProgram.ps1 -Phase pre_push -PushRemoteName "$1" -PushRemoteUrl "$2")
printf '%s\n' "$p1_guard_output"
case "$p1_guard_output" in
  *"p1TransitionScopeMode: transition_only"*)
    powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/agent-system/Test-ModuleRunV2PrePushReadiness.ps1 -P1TransitionScopeMode transition_only
    ;;
  *)
    powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/agent-system/Test-ModuleRunV2PrePushReadiness.ps1
    ;;
esac
